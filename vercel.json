{
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "buildCommand": "apt-get update && apt-get install -y python3 python3-pip && pip3 install Pillow"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/media/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ]
}
